# Copy to .env for local (non-docker-compose) runs. When using
# docker-compose, these are already set via docker-compose.yml's
# environment: block — this file matters if you ever run uvicorn directly
# on your host instead.

POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer
ENVIRONMENT=local
LOG_LEVEL=INFO

# ---------------------------------------------------------------
# NOTE: as of the Stage 4 private-networking change, Azure Database for
# PostgreSQL is on a PRIVATE VNet-only network — it is NO LONGER reachable
# from local docker-compose (this Codespace is not inside the VNet; only
# AKS pods are). The settings above now only work for the LOCAL
# docker-compose "db" service. To test against the real Azure database,
# use the AKS deployment (see k8s/README.md) instead.
# ---------------------------------------------------------------

# ---------------------------------------------------------------
# To fetch POSTGRES_PASSWORD from Key Vault instead of setting it here
# directly, set this (leave POSTGRES_PASSWORD as-is — it gets overwritten
# at startup once Key Vault fetch succeeds):
#
#   KEY_VAULT_URI=<terraform output key_vault_uri>
#
# Requires `az login` on the Codespace host first — docker-compose.yml
# mounts your host's az CLI session into the container so it can
# authenticate the same way.
# ---------------------------------------------------------------
