# Copy to .env for local (non-docker-compose) runs. When using
# docker-compose, these are already set via docker-compose.yml's
# environment: block — this file matters if you ever run uvicorn directly
# on your host instead.

POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer
ENVIRONMENT=local
LOG_LEVEL=INFO

# ---------------------------------------------------------------
# To point the app at Azure Database for PostgreSQL instead of the
# local docker-compose "db" service, copy this file to .env (gitignored —
# never commit real credentials) and override with:
#
#   POSTGRES_HOST=<terraform output postgres_fqdn>
#   POSTGRES_USER=<terraform output postgres_admin_username>
#   POSTGRES_PASSWORD=<terraform output -raw postgres_admin_password>
#   POSTGRES_DB=appdb
#   POSTGRES_SSLMODE=require
#
# docker-compose.yml reads this same .env file automatically for variable
# substitution — no need to edit docker-compose.yml itself.
# ---------------------------------------------------------------

# ---------------------------------------------------------------
# To fetch POSTGRES_PASSWORD from Key Vault instead of setting it here
# directly, set this (leave POSTGRES_PASSWORD as-is — it gets overwritten
# at startup once Key Vault fetch succeeds):
#
#   KEY_VAULT_URI=<terraform output key_vault_uri>
#
# Requires `az login` on the Codespace host first — docker-compose.yml
# mounts your host's az CLI session into the container so it can
# authenticate the same way.
# ---------------------------------------------------------------
